{{define "public/footer"}}
{{/* AI.md PART 16: Footer contains About, Privacy, Contact, Help, GitHub, version */}}
<footer class="site-footer">
    {{/* Onion address - shown only if Tor is enabled and running (AI.md PART 16) */}}
    {{ if and .TorEnabled .TorRunning }}
    <p class="footer-onion">
        <a href="/server/help#tor-access" aria-label="Tor Support">&#129365;</a>
        <code class="onion-address">{{.TorAddress}}</code>
        <button type="button" class="copy-btn" data-copy="{{.TorAddress}}" aria-live="polite" aria-label="Copy onion address">&#128203;</button>
    </p>
    {{ end }}

    {{/* Standard page links per spec - /server/* prefix per AI.md PART 14 Route Scopes */}}
    <p>
        <a href="/server/about">About</a>
        <span>&#8226;</span>
        <a href="/server/privacy">Privacy</a>
        <span>&#8226;</span>
        <a href="/server/contact">Contact</a>
        <span>&#8226;</span>
        <a href="/server/help">Help</a>
    </p>

    {{/* Application branding */}}
    <p>
        <a href="https://github.com/apimgr/vidveil" target="_blank">Made with</a> &#10084;&#65039;
        {{if .Version}}<span>&#8226;</span>
        <span>v{{.Version}}</span>{{end}}
    </p>

    {{/* Build stamp */}}
    <p>
        <a href="/server/healthz">Last update: {{.BuildDateTime}}</a>
    </p>
</footer>

{{/* Toast container for notifications */}}
<div id="toast-container" class="toast-container" role="status" aria-live="polite"></div>

{{/* Cookie Consent Banner per AI.md PART 12 - GDPR/CCPA compliance */}}
<div id="cookie-consent" class="cookie-banner" data-sold="false" hidden>
    <div class="cookie-banner-content">
        <span class="cookie-message">
            We use cookies for essential site functionality and, with your consent, for preference-related features. Preference choices are kept in your browser using localStorage and a small theme cookie so pages can render correctly. This data is never sold.
            <a href="/server/privacy" class="policy-link">Privacy Policy</a>
        </span>
        <div class="cookie-buttons">
            <button class="btn-decline" onclick="declineCookies()">Decline</button>
            <button class="btn-accept" onclick="acceptCookies()">Accept</button>
        </div>
    </div>
</div>
<script>
// Cookie Consent per AI.md PART 12
// cookieConsent is a COOKIE (not localStorage) — server reads it per request
// to skip the banner and suppress non-essential tracking. localStorage is NOT used.
(function() {
    var match = document.cookie.match(/(?:^|;\s*)cookieConsent=([^;]*)/);
    var banner = document.getElementById('cookie-consent');
    if (!match) {
        if (banner) banner.hidden = false;
        return;
    }
    try {
        var consent = JSON.parse(decodeURIComponent(match[1]));
        applyConsent(consent);
    } catch (e) {
        // Corrupt cookie — expire it and show the banner
        document.cookie = 'cookieConsent=; path=/; max-age=0; SameSite=Lax';
        if (banner) banner.hidden = false;
    }
})();

function acceptCookies() {
    var consent = { essential: true, preferences: true, analytics: false, timestamp: Date.now() };
    saveAndApplyConsent(consent);
}

function declineCookies() {
    var consent = { essential: true, preferences: false, analytics: false, timestamp: Date.now() };
    saveAndApplyConsent(consent);
}

function saveAndApplyConsent(consent) {
    // Store as cookie — server reads it per request (AI.md PART 12)
    document.cookie = 'cookieConsent=' + encodeURIComponent(JSON.stringify(consent)) +
        '; path=/; max-age=31536000; SameSite=Lax';
    var banner = document.getElementById('cookie-consent');
    if (banner) banner.hidden = true;
    applyConsent(consent);
}

function applyConsent(consent) {
    // cookieConsent JSON carries all categories; no separate preferencesEnabled cookie needed
    if (!consent.preferences) {
        // Expire preference cookies when user declines
        document.cookie = 'theme=; path=/; max-age=0; SameSite=Lax';
        document.cookie = 'lang=; path=/; max-age=0; SameSite=Lax';
    }
}
</script>
{{end}}
