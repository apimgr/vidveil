{{define "home"}}
<!DOCTYPE html>
<html lang="{{.Lang}}" dir="{{.Dir}}" class="theme-{{.Theme}}">
<head>
    {{template "public/head" .}}
</head>
<body>
    <a href="#main-content" class="skip-link">{{ t "a11y.skip_to_main" }}</a>
    {{template "public/header" .}}
    <main class="home" id="main-content" role="main">
        <div class="home-hero">
            <h1>Vidveil</h1>
            <p class="tagline">{{.Description}}</p>

            {{/* Large search form - consistent with nav search styling */}}
            <form action="/search" method="get" class="search-form search-form--large" role="search" aria-label="{{ t "a11y.video_search" }}" onsubmit="return handleSearchSubmit(this)">
                <label for="search-input" class="visually-hidden">{{ t "a11y.search_query" }}</label>
                <div class="search-wrapper">
                    <input type="text"
                           id="search-input"
                           name="q"
                           placeholder="{{ t "search.placeholder" }}"
                           autofocus
                           required
                           aria-required="true"
                           autocomplete="off"
                           aria-label="{{ t "a11y.search_input" }}"
                           aria-autocomplete="list"
                           aria-controls="autocomplete-dropdown">
                    <div id="autocomplete-dropdown"
                         class="autocomplete-dropdown"
                         role="listbox"
                         aria-label="{{ t "a11y.bang_suggestions" }}"
                         hidden></div>
                </div>
                <button type="submit" aria-label="{{ t "search.button" }}" class="search-btn">{{ t "search.button" }}</button>
            </form>

            <p class="bang-hint">{{ t "search.bang_prefix" }} <code>!ph</code> PornHub, <code>!xv</code> XVideos, <code>!xh</code> xHamster, <code>!rt</code> RedTube</p>

            {{/* Unified filters - collapsible on all screen sizes */}}
            {{template "public/filters" (dict "ShowEngines" true "Compact" false)}}
        </div>

        <div id="search-history" class="search-history" role="region" aria-label="{{ t "a11y.recent_searches" }}"></div>

        <div class="engine-stats" role="contentinfo" aria-label="{{ t "a11y.service_stats" }}">
            <span class="stat"><strong>{{.EngineCount}}</strong> {{ t "home.engines" }}</span>
            <span class="divider" aria-hidden="true">|</span>
            <span class="stat">{{ t "home.no_tracking" }}</span>
            <span class="divider" aria-hidden="true">|</span>
            <span class="stat">{{ t "home.tor_support" }}</span>
        </div>
    </main>
    {{template "public/footer" .}}
    {{template "public/scripts" .}}
</body>
</html>
{{end}}
